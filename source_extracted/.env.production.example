# AWS Production Environment Template
AWS_ACCOUNT_ID=your_account_id
AWS_REGION=us-east-1

# Database (RDS)
DB_HOST=exam-db.xxxxx.us-east-1.rds.amazonaws.com
DB_NAME=exam_portal_db
DB_USER=exam_admin
DB_PASSWORD=SecurePasswordRDS123!

# Redis (ElastiCache)
REDIS_HOST=exam-redis.xxxxx.cache.amazonaws.com
REDIS_PASSWORD=

# RabbitMQ (Amazon MQ)
RABBITMQ_HOST=mq-xxxxx.mq.us-east-1.amazonaws.com
RABBITMQ_USER=exam_user
RABBITMQ_PASSWORD=exam_password

# Object Storage (S3)
S3_ENDPOINT=s3.us-east-1.amazonaws.com
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Secrets
JWT_SECRET=GENERATED_64_CHAR_RANDOM_STRING
