# ===========================================================
#  MockTest – Production Environment Variables
#
#  1. Copy this file:   cp .env.production.example .env.production
#  2. Fill in every value below
#  3. NEVER commit .env.production to version control
# ===========================================================

# ── Database ─────────────────────────────────────────────────
DB_NAME=mocktest_db
DB_USER=mocktest_user
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT ──────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 64
JWT_SECRET=CHANGE_ME_very_long_random_base64_string

# ── Email (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
# Use a Gmail App Password (not your account password):
# https://myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
MAIL_FROM_NAME=MockTest Platform

# ── Public URL ────────────────────────────────────────────────
# The URL students and mediators use to reach the site
# (your EC2 public IP or custom domain)
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP
